<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/contactsFragment">

    <fragment
        android:id="@+id/contactsFragment"
        android:name="com.example.ciphrchat.ui_layer.main.contacts.ContactsFragment"
        android:label="fragment_chat"
        tools:layout="@layout/fragment_contacts">
        <action
            android:id="@+id/action_contactsFragment_to_conversationFragment"
            app:destination="@id/conversationFragment" />
    </fragment>
    <fragment
        android:id="@+id/conversationFragment"
        android:name="com.example.ciphrchat.ui_layer.main.conversation.ConversationFragment"
        android:label="fragment_conversation"
        tools:layout="@layout/fragment_conversation">
        <argument
            android:name="peerUsername"
            app:argType="string" />
    </fragment>
    <fragment
        android:id="@+id/onlineUsersFragment"
        android:name="com.example.ciphrchat.ui_layer.main.online_users.OnlineUsersFragment"
        android:label="fragment_friends"
        tools:layout="@layout/fragment_online_users" />
    <fragment
        android:id="@+id/contactRequestsFragment"
        android:name="com.example.ciphrchat.ui_layer.main.contact_request.ContactRequestsFragment"
        android:label="fragment_notifications"
        tools:layout="@layout/fragment_contact_requests" />
</navigation>